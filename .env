# Backend (FastAPI)
# Note: we use `AISB_` prefix to avoid clashing with global env vars (e.g. DEBUG=release).
AISB_DEBUG=false
AISB_DATABASE_URL=postgresql+psycopg://aisb:aisb@localhost:5433/aisb
AISB_JWT_SECRET=change-me
AISB_JWT_ALGORITHM=HS256
AISB_JWT_EXPIRE_MINUTES=1440
AISB_REDIS_URL=redis://localhost:6379/0
AISB_STORAGE_DIR=.data/storage
AISB_UPLOAD_TMP_DIR=.data/uploads
AISB_UPLOAD_CHUNK_SIZE=5242880
AISB_MAX_UPLOAD_BYTES=209715200
